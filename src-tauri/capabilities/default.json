{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/main/tauri-v2-capabilities-schema/schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Matrix client",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "shell:allow-open"
  ]
}
